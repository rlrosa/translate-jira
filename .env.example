JIRA_DOMAIN="example.atlassian.net"
JIRA_EMAIL="your_email@example.com"
JIRA_API_TOKEN="your_jira_api_token"

# --- Optional Features ---
# Required only if using --use-gemini
GEMINI_API_KEY="your_gemini_api_key"

# Healthchecks.io UUID (Recommended for monitoring)
HEALTH_IO_UUID="..."

# --- Translation Configuration (Defaults shown) ---
# The script will use these defaults if variables are not set.
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"
TRANSLATION_SERVER_URL="http://127.0.0.1:5000/translate"
